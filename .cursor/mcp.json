{
  "mcpServers": {
    "wordpress": {
      "command": "npx",
      "args": ["-y", "github:cloudbuilders-jp/mcp-wordpress-server"],
      "env": {
        "WORDPRESS_URL": "https://www.cloudbuilders.jp/",
        "WORDPRESS_USERNAME": "${env:WORDPRESS_USERNAME}",
        "WORDPRESS_APP_PASSWORD": "${env:WORDPRESS_APP_PASSWORD}"
      }
    }
  }
}
