{
  "mcpServers": {
    "wordpress": {
      "command": "node",
      "args": ["<path-to>/mcp-wordpress-server/build/index.js"],
      "env": {
        "WORDPRESS_URL": "<your-wordpress-url>",
        "WORDPRESS_USERNAME": "<your-username>",
        "WORDPRESS_APP_PASSWORD": "<your-app-password>"
      }
    }
  }
}
